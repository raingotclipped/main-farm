local ac = ""
local tc = ""
local UI = {}

pcall(function()
    if makefolder then
        makefolder("PRACTICE_PANEL")
        makefolder("PRACTICE_PANEL/Configs")
    end
end)

local function getConfigs()
    local list = {}
    if listfiles then
        local files = listfiles("PRACTICE_PANEL/Configs")
        for _, file in ipairs(files) do
            local name = file:match("([^/\\]+)%.json$")
            if name then table.insert(list, name) end
        end
    end
    return list
end

local function setVal(el, val)
    if not el then return end
    if el.SetValue then pcall(function() el:SetValue(val) end)
    elseif el.Set then pcall(function() el:Set(val) end) end
end

local function refreshDropdown(el, list)
    if not el then return end
    if el.Refresh then pcall(function() el:Refresh(list) end)
    elseif el.SetValues then pcall(function() el:SetValues(list) end) end
end

local function updateUIElements()
    setVal(UI.Auto1HP, a1)
    setVal(UI.AutoReset, ar)
    setVal(UI.LoopDelay, rt)
    setVal(UI.HPMethod, hm)
    setVal(UI.PinTimeout, pinTimeout)
    setVal(UI.InstantPin, instantPin)
    setVal(UI.TPOnSpawn, tpOnSpawn)
    setVal(UI.TPX, tostring(tpX))
    setVal(UI.TPY, tostring(tpY))
    setVal(UI.TPZ, tostring(tpZ))
    setVal(UI.TPDelay, tpDelay)
end

local function saveConfig(name)
    if not name or name == "" then return end
    local data = {
        Auto1HP    = a1,
        AutoReset  = ar,
        LoopDelay  = rt,
        HPMethod   = hm,
        PinTimeout = pinTimeout,
        InstantPin = instantPin,
        TPOnSpawn  = tpOnSpawn,
        TPX        = tpX,
        TPY        = tpY,
        TPZ        = tpZ,
        TPDelay    = tpDelay,
    }
    local success, str = pcall(function() return hs:JSONEncode(data) end)
    if success and writefile then
        writefile("PRACTICE_PANEL/Configs/" .. name .. ".json", str)
    end
end

local function loadConfig(name)
    if not name or name == "" then return end
    local path = "PRACTICE_PANEL/Configs/" .. name .. ".json"
    if isfile and isfile(path) and readfile then
        local str = readfile(path)
        local success, data = pcall(function() return hs:JSONDecode(str) end)
        if success and type(data) == "table" then
            if data.Auto1HP    ~= nil then a1 = data.Auto1HP end
            if data.AutoReset  ~= nil then ar = data.AutoReset end
            if data.LoopDelay  ~= nil then rt = data.LoopDelay end
            if data.HPMethod   ~= nil then hm = data.HPMethod end
            if data.PinTimeout ~= nil then pinTimeout = data.PinTimeout end
            if data.InstantPin ~= nil then instantPin = data.InstantPin end
            if data.TPOnSpawn  ~= nil then tpOnSpawn = data.TPOnSpawn end
            if data.TPX        ~= nil then tpX = tonumber(data.TPX) or tpX end
            if data.TPY        ~= nil then tpY = tonumber(data.TPY) or tpY end
            if data.TPZ        ~= nil then tpZ = tonumber(data.TPZ) or tpZ end
            if data.TPDelay    ~= nil then tpDelay = tonumber(data.TPDelay) or tpDelay end
            updateUIElements()
        end
    end
end

local function deleteConfig(name)
    if not name or name == "" then return end
    local path = "PRACTICE_PANEL/Configs/" .. name .. ".json"
    if delfile and isfile and isfile(path) then delfile(path) end
end

