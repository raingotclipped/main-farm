local pl = game:GetService("Players")
local rn = game:GetService("RunService")
local rp = game:GetService("ReplicatedStorage")
local ws = game:GetService("Workspace")
local vu = game:GetService("VirtualUser")
local hs = game:GetService("HttpService")
local lp = pl.LocalPlayer

-- ============================================================
-- STATE
-- ============================================================
local a1 = true
local ar = true
local rt = 1.0
local hm = "Kill Signal"
local instantPin = true

-- Pin echo tracking
local pinning      = false
local stableAtOne  = false
local pinTimeout   = 0.2
local pinToken     = 0
local sc           = false

-- Teleport-on-Spawn
local tpOnSpawn    = false
local tpX          = -21.608
local tpY          = -61.689
local tpZ          = -251.675
local tpDelay      = 0.5  -- seconds after spawn before TP attempt

local ds = { enabled = false, loc = CFrame.new() }
local killTarget = nil

-- Safe, non-blocking remote resolution
local rst
task.spawn(function()
    while not rst do
        pcall(function()
            rst = rp.Knit.Knit.Services.JoinService.RE.Reset
        end)
        task.wait(0.5)
    end
end)

----------------------------------------------------------------
-- HOOKS
----------------------------------------------------------------
local oi
oi = hookmetamethod(game, "__index", newcclosure(function(self, k)
    if ds.enabled and not checkcaller() and k == "CFrame" then
        local c = lp.Character
        if c then
            local hrp = c:FindFirstChild("HumanoidRootPart")
            if hrp and self == hrp then
                return ds.loc
            end
        end
    end
    return oi(self, k)
end))

local function gc()
    local c = lp.Character
    if c and c.Parent then return c end
    local f = ws:FindFirstChild("Characters")
    return f and f:FindFirstChild(lp.Name)
end

local ncc = nil
local cm = {}

local function ncf(dur)
    if ncc then ncc:Disconnect() ncc = nil end
    cm = {}
    local function step()
        local c = gc()
        if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then
                if cm[p] == nil then cm[p] = p.CanCollide end
                p.CanCollide = false
            end
        end
    end
    step()
    ncc = rn.Stepped:Connect(step)
    task.delay(dur, function()
        if ncc then ncc:Disconnect() ncc = nil end
        local c = gc()
        if c then
            for p, old in pairs(cm) do
                if p and p.Parent then p.CanCollide = old end
            end
        end
        cm = {}
    end)
end

local function rc()
    if ncc then ncc:Disconnect() ncc = nil end
    cm = {}
end

local hb

local function de()
    if ds.enabled then return end
    local c = gc()
    if not c then return end
    local r = c:FindFirstChild("HumanoidRootPart")
    local h = c:FindFirstChildOfClass("Humanoid")
    if not r or not h then return end

    pinning     = false
    stableAtOne = false

    ncf(5)
    ds.enabled = true
    ds.loc = r.CFrame

    pcall(function() replicatesignal(h.ServerBreakJoints) end)
    if rst then pcall(function() rst:FireServer() end) end

    if hb then hb:Disconnect() hb = nil end
    hb = rn.Heartbeat:Connect(function()
        if not ds.enabled then
            if hb then hb:Disconnect() hb = nil end
            return
        end
        local char = gc()
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root and root.Parent then
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            root.CFrame = CFrame.new(0, 10000, 0)
        end
    end)

    task.delay(0.5, function()
        ds.enabled = false
        if hb then hb:Disconnect() hb = nil end
    end)
end

local oldNc
oldNc = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if not checkcaller() and self == rst and (method == "FireServer" or method == "fireServer") then
        if ar and not pinning and not sc then
            if hb then hb:Disconnect() hb = nil end
            ds.enabled = false
            task.spawn(de)
        end
    end
    return oldNc(self, ...)
end))

----------------------------------------------------------------
-- LOGIC
----------------------------------------------------------------
local function s1()
    local c = gc()
    if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if not h then return end
    if h.Health <= 1.01 then return end

    pinning     = true
    stableAtOne = false
    pinToken    = pinToken + 1
    local myToken = pinToken

    pcall(function()
        if hm == "ChangeState" then
            h:ChangeState(Enum.HumanoidStateType.Dead)
        elseif hm == "Kill Signal" then
            local sig = replicatesignal or replicate_signal
            if sig and killTarget then
                sig(killTarget)
            else
                h:ChangeState(Enum.HumanoidStateType.Dead)
            end
        end
    end)

    task.delay(pinTimeout, function()
        if myToken == pinToken and pinning then
            pinning     = false
            stableAtOne = true
        end
    end)
end

local function fr()
    pinning     = false
    stableAtOne = false
    task.spawn(de)
end

-- ============================================================
-- TELEPORT-ON-SPAWN
-- ============================================================
local function tryTPOnSpawn(char)
    if not tpOnSpawn then return end
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end

    -- Wait a brief moment for spawn physics to settle
    task.wait(tpDelay)
    if not hrp or not hrp.Parent then return end

    local target = CFrame.new(tpX, tpY, tpZ)
    pcall(function()
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.CFrame = target
    end)
end

-- ============================================================
-- LOOP — safety-net pin
-- ============================================================
task.spawn(function()
    while true do
        task.wait(rt)
        if a1 and not pinning and not sc and not ds.enabled then
            local c = gc()
            local h = c and c:FindFirstChildOfClass("Humanoid")
            if h and h.Parent and h.Health > 1.01 then
                s1()
            end
        end
    end
end)

local function bd(char)
    rc()
    sc          = true
    pinning     = false
    stableAtOne = false

    pcall(function()
        if lp:FindFirstChild("kill") then
            killTarget = lp.kill
        elseif lp.kill then
            killTarget = lp.kill
        end
    end)

    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if hrp then
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        if ds.enabled then
            hrp.CFrame = ds.loc
            task.spawn(function()
                for i = 1, 5 do
                    rn.Heartbeat:Wait()
                    if hrp and hrp.Parent then
                        hrp.AssemblyLinearVelocity = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                        hrp.CFrame = ds.loc
                    end
                end
            end)
        end
    end

    task.delay(0.6, function() sc = false end)

    -- Fire teleport-on-spawn (separate task so it doesn't block humanoid setup)
    task.spawn(tryTPOnSpawn, char)

    local hum = char:WaitForChild("Humanoid", 5)
    if hum then
        local lastHP = hum.Health

        hum.Died:Connect(function()
            if not ar then return end
            if sc then return end
            if ds.enabled then return end
            if pinning then return end
            task.spawn(de)
        end)

        hum.HealthChanged:Connect(function(hp)
            if ds.enabled then return end
            if sc then return end

            if pinning then
                if hp > 0.5 and hp < 2 then
                    pinning     = false
                    stableAtOne = true
                end
                lastHP = hp
                return
            end

            if ar and hp <= 0 then
                stableAtOne = false
                task.spawn(de)
                lastHP = hp
                return
            end

            if ar and stableAtOne and lastHP > 0 and hp < lastHP and hp <= 0.5 then
                stableAtOne = false
                task.spawn(de)
                lastHP = hp
                return
            end

            if a1 and instantPin and hp > 1.01 then
                s1()
            end

            lastHP = hp
        end)
    end

    task.spawn(function()
        local regen = char:WaitForChild("Health", 5)
        if regen and regen:IsA("Script") then regen.Disabled = true end
    end)
end

lp.CharacterAdded:Connect(bd)
if lp.Character then
    task.spawn(bd, lp.Character)
end

lp.Idled:Connect(function()
    pcall(function()
        vu:CaptureController()
        vu:ClickButton2(Vector2.new())
    end)
end)

