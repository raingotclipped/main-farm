local function sortTargetsByProximity(tps)
    local density, minDistance, positions = {}, {}, {}
    for _, p in ipairs(tps) do
        local ok, hrp = isValidTarget(p)
        if ok then positions[p] = hrp.Position end
    end
    for _, p1 in ipairs(tps) do
        local pos1 = positions[p1]
        if pos1 then
            local count, minDist = 0, 999999
            for _, p2 in ipairs(tps) do
                if p1 ~= p2 then
                    local pos2 = positions[p2]
                    if pos2 then
                        local dist = (pos1 - pos2).Magnitude
                        if dist < 50 then count = count + 1 end
                        if dist < minDist then minDist = dist end
                    end
                end
            end
            density[p1] = count
            minDistance[p1] = minDist
        else
            density[p1] = -1
            minDistance[p1] = 999999
        end
    end
    table.sort(tps, function(a, b)
        local denA, denB = density[a] or -1, density[b] or -1
        if denA ~= denB then return denA > denB end
        return (minDistance[a] or 999999) < (minDistance[b] or 999999)
    end)
end

local function runMultiTP()
    if multiBusy then return end
    if #State.MultiTargets == 0 then return end
    multiBusy = true
    startCamLock()

    repeat
        local tps = {}
        for _, name in ipairs(State.MultiTargets) do
            local p = findTargetByDisplay(name)
            if p then table.insert(tps, p) end
        end
        if #tps == 0 then task.wait(0.5) continue end

        if State.TargetOrder == "Proximity" then
            sortTargetsByProximity(tps)
        end

        for _, tp in ipairs(tps) do
            if not multiBusy then break end
            currentTarget = tp

            if State.MultiMode == "Smart" then
                local waitStart = os.clock()
                local committed = false
                while multiBusy do
                    if isDead(tp) then break end
                    local hp = getTargetHealth(tp)
                    if hp and hp <= State.SmartHPThresh then
                        committed = true
                        break
                    end
                    if os.clock() - waitStart > State.SmartWaitMax then break end
                    task.wait(0.05)
                end
                if not committed then
                    currentTarget = nil
                    if State.MultiDelay > 0 then task.wait(State.MultiDelay) end
                    continue
                end
            end

            local deadFrames = 0
            while multiBusy do
                if isDead(tp) then
                    deadFrames = deadFrames + 1
                    if deadFrames >= 5 then break end
                else
                    deadFrames = 0
                end

                if State.MultiMode == "Smart" then
                    local liveHP = getTargetHealth(tp)
                    if liveHP and liveHP > State.SmartHPThresh and not isDead(tp) then
                        break
                    end
                end

                local ok, thrp = isValidTarget(tp)
                if ok then
                    local mc = lp.Character
                    local mhrp = mc and mc:FindFirstChild("HumanoidRootPart")
                    local mhum = mc and mc:FindFirstChildOfClass("Humanoid")
                    if mhrp and mhum then
                        mhrp.AssemblyLinearVelocity = Vector3.zero
                        mhrp.AssemblyAngularVelocity = Vector3.zero
                        local goal
                        if State.MultiMode == "Under" then
                            mhum.PlatformStand = true
                            goal = getUnderCFrame(thrp, State.OffsetUnder, State.UnderRot)
                            if not invisOn then updateCam(thrp.Position) end
                        elseif State.MultiMode == "Exact" then
                            mhum.PlatformStand = false
                            if not invisOn then resetCam() end
                            goal = thrp.CFrame
                        else
                            mhum.PlatformStand = false
                            if not invisOn then resetCam() end
                            goal = getBehindCFrame(thrp, State.OffsetBehind, State.OffsetY)
                        end
                        mhrp.CFrame = goal
                    end
                end
                rs.Heartbeat:Wait()
            end

            currentTarget = nil
            if State.MultiDelay > 0 then
                task.wait(State.MultiDelay)
            end
        end
        task.wait(0.01)
    until not State.MultiLoop or not multiBusy

    multiBusy = false
    currentTarget = nil
    stopCamLock()
    resetCam()
    local mc = lp.Character
    local mhum = mc and mc:FindFirstChildOfClass("Humanoid")
    if mhum then mhum.PlatformStand = false end
end

