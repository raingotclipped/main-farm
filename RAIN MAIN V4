local function startCamLock()
    if camLockConn then return end
    camLockConn = rs.RenderStepped:Connect(function()
        if not multiBusy then return end
        if not currentTarget then return end
        if not invisOn then return end

        local ok, thrp = isValidTarget(currentTarget)
        if not ok or not thrp then return end

        if cam.CameraType ~= Enum.CameraType.Scriptable then
            cam.CameraType = Enum.CameraType.Scriptable
        end

        local L = thrp.CFrame.LookVector
        local flat = Vector3.new(L.X, 0, L.Z)
        if flat.Magnitude < 0.01 then return end
        flat = flat.Unit

        local camPos = thrp.Position - flat * State.BackCamDist + Vector3.new(0, State.BackCamHeight, 0)
        local lookAt = thrp.Position + flat * 10
        cam.CFrame = CFrame.lookAt(camPos, lookAt)
    end)
end

local function stopCamLock()
    if camLockConn then camLockConn:Disconnect() camLockConn = nil end
    pcall(function()
        cam.CameraType = Enum.CameraType.Custom
        if invisOn and ft then
            cam.CameraSubject = ft
        elseif lp.Character then
            local h = lp.Character:FindFirstChildOfClass("Humanoid")
            if h then cam.CameraSubject = h end
        end
    end)
    currentTarget = nil
end

