local function findTargetByDisplay(name)
    if not name then return nil end
    name = name:lower()
    for _, plr in ipairs(ps:GetPlayers()) do
        if plr ~= lp then
            if plr.DisplayName:lower() == name or plr.Name:lower() == name then return plr end
        end
    end
    for _, plr in ipairs(ps:GetPlayers()) do
        if plr ~= lp and plr.DisplayName:lower():find(name, 1, true) then return plr end
    end
    return nil
end

local function isValidTarget(plr)
    if not plr or not plr.Parent then return false end
    local c = plr.Character
    if not c then return false end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then return false end
    return true, hrp
end

local function isDead(plr)
    if not plr or not plr.Parent then return true end
    local c = plr.Character
    if not c then return true end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return true end
    return false
end

local function getTargetHealth(plr)
    if not plr or not plr.Parent then return nil end
    local c = plr.Character
    if not c then return nil end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    return hum.Health
end

local function getBehindCFrame(targetHRP, offset, yOff)
    local lookBack = targetHRP.CFrame.LookVector * -offset
    local pos = targetHRP.Position + lookBack + Vector3.new(0, yOff or 0, 0)
    return CFrame.new(pos, targetHRP.Position)
end

local function getUnderCFrame(targetHRP, offset, rotAngle)
    local pos = targetHRP.Position - Vector3.new(0, offset or 3, 0)
    local look = targetHRP.CFrame.LookVector
    local flatLook = Vector3.new(look.X, 0, look.Z).Unit
    local baseCF = CFrame.lookAt(pos, pos + flatLook)
    return baseCF * CFrame.Angles(math.rad(rotAngle or 90), 0, 0)
end

local function getPlayerList()
    local t = {}
    for _, plr in ipairs(ps:GetPlayers()) do
        if plr ~= lp then table.insert(t, plr.DisplayName) end
    end
    return t
end

-- Build whitelist set from State.LockTargets
local function buildLockWhitelist()
    if not State.LockTargets or #State.LockTargets == 0 then return nil end
    local set = {}
    for _, name in ipairs(State.LockTargets) do
        set[name:lower()] = true
    end
    return set
end

local function isInLockWhitelist(plr, set)
    if not set then return true end -- nil = allow all
    if set[plr.DisplayName:lower()] then return true end
    if set[plr.Name:lower()] then return true end
    return false
end

-- Nearest alive target within range, respecting whitelist
local function findNearestPlayer(range)
    local myChar = lp.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    local whitelist = buildLockWhitelist()

    local best, bestDist = nil, math.huge
    for _, plr in ipairs(ps:GetPlayers()) do
        if plr ~= lp and isInLockWhitelist(plr, whitelist) then
            local ok, thrp = isValidTarget(plr)
            if ok then
                local d = (thrp.Position - myHRP.Position).Magnitude
                if d <= range and d < bestDist then
                    bestDist = d
                    best = plr
                end
            end
        end
    end
    return best
end

