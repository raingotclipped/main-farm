----------------------------------------------------------------
-- FACE TARGET (rotation ONLY)
----------------------------------------------------------------
local function startFaceTarget()
    if faceConn then return end

    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum and savedAutoRotate == nil then
        savedAutoRotate = hum.AutoRotate
    end

    faceConn = rs.RenderStepped:Connect(function()
        if not State.LockOnEnabled then return end
        if not State.FaceTargetEnabled then return end
        if not lockOnTarget then return end

        local myChar = lp.Character
        if not myChar then return end
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        local myHum = myChar:FindFirstChildOfClass("Humanoid")
        if not myHRP or not myHum then return end

        if myHum.AutoRotate then myHum.AutoRotate = false end

        local ok, thrp = isValidTarget(lockOnTarget)
        if not ok or not thrp then return end

        local myPos = myHRP.Position
        local tPos  = thrp.Position
        local diff  = tPos - myPos
        local flat  = Vector3.new(diff.X, 0, diff.Z)
        if flat.Magnitude < 0.01 then return end

        local newCF = CFrame.new(myPos, myPos + flat.Unit)
        if myHRP.CFrame ~= newCF then
            myHRP.CFrame = newCF
        end
    end)
end

local function stopFaceTarget()
    if faceConn then faceConn:Disconnect() faceConn = nil end
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.AutoRotate = (savedAutoRotate == nil) or savedAutoRotate
    end
    savedAutoRotate = nil
end

----------------------------------------------------------------
-- LOCK ON
----------------------------------------------------------------
local function stopLockOn()
    if lockOnConn then lockOnConn:Disconnect() lockOnConn = nil end
    lockOnTarget = nil
    stopFaceTarget()
    pcall(function()
        if cam.CameraType == Enum.CameraType.Scriptable then
            cam.CameraType = Enum.CameraType.Custom
        end
        if invisOn and ft then
            cam.CameraSubject = ft
        else
            local h = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
            if h then cam.CameraSubject = h end
        end
    end)
end

local function startLockOn()
    if lockOnConn then return end
    if State.FaceTargetEnabled then startFaceTarget() end
    lockOnConn = rs.RenderStepped:Connect(function()
        if not State.LockOnEnabled then return end

        local myChar = lp.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        local whitelist = buildLockWhitelist()

        local needNew = false
        if not lockOnTarget then
            needNew = true
        else
            local ok, thrp = isValidTarget(lockOnTarget)
            if not ok or not thrp then
                needNew = true
            elseif not isInLockWhitelist(lockOnTarget, whitelist) then
                needNew = true
            else
                local dist = (thrp.Position - myHRP.Position).Magnitude
                if dist > State.LockOnRange then needNew = true end
            end
        end

        if needNew then
            lockOnTarget = findNearestPlayer(State.LockOnRange)
            if not lockOnTarget then
                if cam.CameraType == Enum.CameraType.Scriptable then
                    cam.CameraType = Enum.CameraType.Custom
                    if invisOn and ft then
                        cam.CameraSubject = ft
                    else
                        local h = myChar:FindFirstChildOfClass("Humanoid")
                        if h then cam.CameraSubject = h end
                    end
                end
                return
            end
        end

        local ok, thrp = isValidTarget(lockOnTarget)
        if not ok or not thrp then return end

        if cam.CameraType ~= Enum.CameraType.Scriptable then
            cam.CameraType = Enum.CameraType.Scriptable
        end

        local L = thrp.CFrame.LookVector
        local flat = Vector3.new(L.X, 0, L.Z)
        if flat.Magnitude < 0.01 then return end
        flat = flat.Unit

        local camPos = thrp.Position - flat * State.LockCamDist + Vector3.new(0, State.LockCamHeight, 0)
        local lookAt = thrp.Position + flat * 10
        cam.CFrame = CFrame.lookAt(camPos, lookAt)
    end)
end

