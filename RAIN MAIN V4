local function disableInvis()
    if invisConn then invisConn:Disconnect() invisConn = nil end
    if ft then pcall(function() ft:Destroy() end) ft = nil end
    if invisTrack then pcall(function() invisTrack:Stop(0) end) invisTrack = nil end

    local char = lp.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hrp and oC0 then
            local rj = hrp:FindFirstChild("RootJoint")
                or (char:FindFirstChild("LowerTorso") and char.LowerTorso:FindFirstChild("Root"))
            if rj then pcall(function() rj.C0 = oC0 end) end
        end
        if hum then hum.AutoRotate = true end
    end

    pcall(function()
        cam.CameraType = Enum.CameraType.Custom
        if lp.Character then
            local hum = lp.Character:FindFirstChildOfClass("Humanoid")
            if hum then cam.CameraSubject = hum end
        end
    end)
    oC0 = nil
end

local function setInvis(char)
    char = char or lp.Character
    if not char then return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    local rj = hrp:FindFirstChild("RootJoint")
        or (char:FindFirstChild("LowerTorso") and char.LowerTorso:FindFirstChild("Root"))
    if rj then
        oC0 = rj.C0
        rj.C0 = oC0 - Vector3.new(0, INVIS_OFF, 0)
    end

    hum.AutoRotate = false
    lp.DevEnableMouseLock = true

    if ft then pcall(function() ft:Destroy() end) end
    ft = Instance.new("Part")
    ft.Name = "JJSFakeTorso"
    ft.Size = Vector3.new(2, 2, 1)
    ft.Transparency = 1
    ft.CanCollide = false
    ft.Anchored = true
    ft.Parent = workspace

    cam.CameraType = Enum.CameraType.Custom
    cam.CameraSubject = ft

    if invisConn then invisConn:Disconnect() end
    invisConn = rs.RenderStepped:Connect(function()
        if not invisOn then return end
        local c2 = lp.Character
        if not c2 then return end
        local hrp2 = c2:FindFirstChild("HumanoidRootPart")
        if not hrp2 then return end

        local rj2 = hrp2:FindFirstChild("RootJoint")
            or (c2:FindFirstChild("LowerTorso") and c2.LowerTorso:FindFirstChild("Root"))
        if rj2 and oC0 then
            local target = oC0 - Vector3.new(0, INVIS_OFF, 0)
            if rj2.C0 ~= target then rj2.C0 = target end
        end

        for _, p in ipairs(c2:GetDescendants()) do
            if p:IsA("BasePart") and p.CanCollide then
                p.CanCollide = false
            end
        end

        local lookDir
        local lockedT = currentTarget or lockOnTarget
        if lockedT and isValidTarget(lockedT) then
            local _, thrp = isValidTarget(lockedT)
            if thrp then
                local d = thrp.Position - hrp2.Position
                lookDir = Vector3.new(d.X, 0, d.Z)
            end
        end
        if not lookDir or lookDir.Magnitude < 0.01 then
            local camCF = cam.CFrame
            lookDir = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z)
        end
        if lookDir.Magnitude > 0 then
            lookDir = lookDir.Unit
            hrp2.CFrame = CFrame.new(hrp2.Position, hrp2.Position + lookDir)
        end
        if ft then ft.CFrame = hrp2.CFrame * CFrame.new(0, 1.5, 0) end
    end)

    pcall(function()
        local anim = rep.Modules.MVP.Meditation.Character
        invisTrack = hum:LoadAnimation(anim)
        invisTrack.Priority = Enum.AnimationPriority.Action4
        invisTrack:Play()
        task.wait(0.1)
        invisTrack.TimePosition = 0.1
        invisTrack:AdjustSpeed(0)
        for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
            if t ~= invisTrack then t:Stop(0) end
        end
        hum.AnimationPlayed:Connect(function(t)
            if not invisOn then return end
            if t ~= invisTrack then t:Stop(0) end
        end)
    end)
end

