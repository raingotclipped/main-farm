local function updateCam(pos)
    if not camProxy or not camProxy.Parent then
        camProxy = Instance.new("Part")
        camProxy.Name = "CamProxy"
        camProxy.Size = Vector3.new(1, 1, 1)
        camProxy.Transparency = 1
        camProxy.CanCollide = false
        camProxy.Anchored = true
        camProxy.Parent = workspace
    end
    camProxy.CFrame = CFrame.new(pos)
    if cam.CameraSubject ~= camProxy then
        cam.CameraSubject = camProxy
    end
end

local function resetCam()
    if camProxy then
        pcall(function() camProxy:Destroy() end)
        camProxy = nil
    end
    if invisOn and ft then
        cam.CameraSubject = ft
        return
    end
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum and cam.CameraSubject ~= hum then
        cam.CameraSubject = hum
    end
end

