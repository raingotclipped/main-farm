    Placeholder = "-251.675",
    Value       = tostring(tpZ),
    Callback    = function(v)
        local n = tonumber(v)
        if n then tpZ = n end
    end,
})

UI.TPDelay = TPTab:Slider({
    Title    = "TP Delay After Spawn (s)",
    Step     = 0.05,
    Value    = { Min = 0.0, Max = 3.0, Default = 0.5 },
    Callback = function(v) tpDelay = tonumber(v) or tpDelay end,
})

TPTab:Section({ Title = "Manual" })

TPTab:Button({
    Title = "Teleport Now",
    Callback = function()
        local c = gc()
        local hrp = c and c:FindFirstChild("HumanoidRootPart")
        if hrp then
            pcall(function()
                hrp.AssemblyLinearVelocity  = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                hrp.CFrame = CFrame.new(tpX, tpY, tpZ)
            end)
        end
    end,
})

TPTab:Button({
    Title = "Re-Engage TP Hold",
    Callback = function()
        if tpOnSpawn then startTPHold() end
    end,
})

TPTab:Button({
    Title = "Release TP Hold",
    Callback = function() stopTPHold() end,
})

TPTab:Button({
    Title = "Set From Current Position",
    Callback = function()
        local c = gc()
        local hrp = c and c:FindFirstChild("HumanoidRootPart")
        if hrp then
            local p = hrp.Position
            tpX = math.floor(p.X * 1000 + 0.5) / 1000
            tpY = math.floor(p.Y * 1000 + 0.5) / 1000
            tpZ = math.floor(p.Z * 1000 + 0.5) / 1000
            setVal(UI.TPX, tostring(tpX))
            setVal(UI.TPY, tostring(tpY))
            setVal(UI.TPZ, tostring(tpZ))
        end
    end,
})

----------------------------------------------------------------
-- CONFIGS TAB
----------------------------------------------------------------
local ConfigTab = Window:Tab({ Title = "Configs", Icon = "settings" })

ConfigTab:Section({ Title = "Manage Configurations" })

local cd

ConfigTab:Input({
    Title = "Config Name",
    Placeholder = "Enter name here...",
    Callback = function(v) tc = v end,
})

cd = ConfigTab:Dropdown({
    Title = "Select Config",
    Values = getConfigs(),
    Default = "",
    Callback = function(v) ac = v end,
})

ConfigTab:Button({
    Title = "Save Config",
    Callback = function()
        if tc ~= "" then
            saveConfig(tc)
            refreshDropdown(cd, getConfigs())
        end
    end,
})

ConfigTab:Button({
    Title = "Overwrite Config",
    Callback = function()
        if ac ~= "" then saveConfig(ac) end
    end,
})

ConfigTab:Button({
    Title = "Load Config",
    Callback = function()
        if ac ~= "" then loadConfig(ac) end
    end,
})

ConfigTab:Button({
    Title = "Delete Config",
    Callback = function()
        if ac ~= "" then
            deleteConfig(ac)
            ac = ""
            refreshDropdown(cd, getConfigs())
        end
    end,
})

ConfigTab:Section({ Title = "Autoload Settings" })

ConfigTab:Button({
    Title = "Set as Autoload Config",
    Callback = function()
        if ac ~= "" and writefile then
            writefile("PRACTICE_PANEL/autoload.txt", ac)
        end
    end,
})

ConfigTab:Button({
    Title = "Clear Autoload Config",
    Callback = function()
        if isfile and isfile("PRACTICE_PANEL/autoload.txt") and delfile then
            delfile("PRACTICE_PANEL/autoload.txt")
        end
    end,
})

