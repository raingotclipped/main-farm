----------------------------------------------------------------
local function de()
    if ds.enabled or resetting then return end
    local c = gc()
    if not c then return end
    local r = c:FindFirstChild("HumanoidRootPart")
    local h = c:FindFirstChildOfClass("Humanoid")
    if not r or not h then return end

    resetting   = true
    pinning     = false
    stableAtOne = false
    stopTPHold()

    ncf(5)
    ds.enabled = true
    ds.loc = r.CFrame

    executeResetMethod(h)

    if hb then hb:Disconnect() hb = nil end
    hb = rn.Heartbeat:Connect(function()
        if not ds.enabled then
            if hb then hb:Disconnect() hb = nil end
            return
        end
        local char = gc()
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root and root.Parent then
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            root.CFrame = CFrame.new(0, 10000, 0)
        end
    end)

    task.delay(0.5, function()
        ds.enabled = false
        if hb then hb:Disconnect() hb = nil end
    end)
end

local oldNc
oldNc = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if not checkcaller() and self == rst and (method == "FireServer" or method == "fireServer") then
        if ar and not pinning and not sc and not resetting then
            if hb then hb:Disconnect() hb = nil end
            ds.enabled = false
            task.spawn(de)
        end
    end
    return oldNc(self, ...)
end))

----------------------------------------------------------------
-- 1HP PIN
----------------------------------------------------------------
local function s1()
    if resetting or ds.enabled or sc then return end
    local c = gc()
    if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if not h then return end
    if h.Health <= 1.01 then return end

    pinning     = true
    stableAtOne = false
    pinToken    = pinToken + 1
    local myToken = pinToken

    pcall(function()
        if hm == "ChangeState" then
            h:ChangeState(Enum.HumanoidStateType.Dead)
        elseif hm == "Kill Signal" then
            local sig = replicatesignal or replicate_signal
            if sig and killTarget then
                sig(killTarget)
            else
                h:ChangeState(Enum.HumanoidStateType.Dead)
            end
        end
    end)

    task.delay(pinTimeout, function()
        if myToken == pinToken and pinning then
            pinning     = false
            stableAtOne = true
        end
    end)
end

local function fr()
    pinning     = false
    stableAtOne = false
    task.spawn(de)
end

-- ============================================================
-- 1HP SAFETY LOOP
-- ============================================================
task.spawn(function()
    while true do
        task.wait(rt)
        if a1 and not pinning and not sc and not ds.enabled and not resetting then
            local c = gc()
            local h = c and c:FindFirstChildOfClass("Humanoid")
            if h and h.Parent and h.Health > 1.01 then
                s1()
            end
        end
    end
end)

----------------------------------------------------------------
-- ANIMATION DETECTION
----------------------------------------------------------------
local function normalizeId(id)
    if not id then return "" end
    local n = tostring(id):match("(%d+)")
    return n or ""
end

local function onTrackPlayed(track)
    if not animWatch or animDetectDebounce or resetting or ds.enabled then return end
    if not track or not track.Animation then return end
    local trackId = normalizeId(track.Animation.AnimationId)
    local targetId = normalizeId(animId)
    if trackId == "" or targetId == "" then return end
    if trackId ~= targetId then return end

    -- HIT — fire reset
    animDetectDebounce = true
    stopTPHold()
    if ar then
        task.spawn(de)
    end
    task.delay(1.0, function() animDetectDebounce = false end)
end

local function hookHumanoid(hum)
    if not hum or animTrackedHums[hum] then return end
    -- Catch the moment any track starts
    local conn = hum.AnimationPlayed:Connect(onTrackPlayed)
    animTrackedHums[hum] = conn
    -- Also sweep currently-playing tracks (anim may have started before hook)
    pcall(function()
        for _, tr in ipairs(hum:GetPlayingAnimationTracks()) do
            onTrackPlayed(tr)
        end
    end)
    -- Auto-cleanup
    hum.AncestryChanged:Connect(function(_, parent)
        if not parent then
            if animTrackedHums[hum] then
                animTrackedHums[hum]:Disconnect()
                animTrackedHums[hum] = nil
            end
        end
    end)
end

local function unhookAll()
    for hum, conn in pairs(animTrackedHums) do
        if conn then conn:Disconnect() end
        animTrackedHums[hum] = nil
    end
end

-- Scan loop: keep hooks up-to-date for everyone within range
task.spawn(function()
    while true do
        rn.Heartbeat:Wait()
        if not animWatch or resetting or ds.enabled then
            -- Idle
        else
            local c = gc()
            local myRoot = c and c:FindFirstChild("HumanoidRootPart")
            if myRoot then
                local myPos = myRoot.Position
                -- Search all character folders likely to hold mobs/players
                local searchRoots = {}
                table.insert(searchRoots, ws)
                local chFolder = ws:FindFirstChild("Characters")
                if chFolder then table.insert(searchRoots, chFolder) end
                local enemies = ws:FindFirstChild("Enemies") or ws:FindFirstChild("NPCs") or ws:FindFirstChild("Mobs")
                if enemies then table.insert(searchRoots, enemies) end

                -- Walk Players' characters
                for _, p in ipairs(pl:GetPlayers()) do
                    if p ~= lp and p.Character then
                        local hum = p.Character:FindFirstChildOfClass("Humanoid")
                        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                        if hum and hrp and (hrp.Position - myPos).Magnitude <= animRange then
                            hookHumanoid(hum)
                        end
                    end
                end

                -- Walk workspace humanoids (NPCs / enemies)
                for _, model in ipairs(ws:GetDescendants()) do
                    if model:IsA("Humanoid") then
                        local par = model.Parent
                        local hrp = par and (par:FindFirstChild("HumanoidRootPart") or par:FindFirstChild("Torso") or par:FindFirstChild("UpperTorso"))
                        if hrp and hrp:IsA("BasePart") and (hrp.Position - myPos).Magnitude <= animRange then
                            hookHumanoid(model)
                        end
                    end
                end
            end
        end
    end
end)

----------------------------------------------------------------
-- CHARACTER BIND
----------------------------------------------------------------
local function bd(char)
    rc()
    stopTPHold()
    sc          = true
    pinning     = false
    stableAtOne = false
    animDetectDebounce = false

    pcall(function()
        if lp:FindFirstChild("kill") then
            killTarget = lp.kill
        elseif lp.kill then
            killTarget = lp.kill
        end
    end)

    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if hrp then
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        if ds.enabled then
            hrp.CFrame = ds.loc
            task.spawn(function()
                for i = 1, 5 do
                    rn.Heartbeat:Wait()
                    if hrp and hrp.Parent then
                        hrp.AssemblyLinearVelocity = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                        hrp.CFrame = ds.loc
                    end
                end
            end)
        end
    end

    task.delay(0.6, function()
        sc = false
        resetting = false
    end)

    -- Schedule TP hold re-engagement on this new character
    tpSession = tpSession + 1
    local mySession = tpSession
    task.delay(math.max(tpDelay, 0.65), function()
        if mySession ~= tpSession then return end
        if not tpOnSpawn then return end
        if resetting or ds.enabled then return end
        local cc = gc()
        if cc ~= char then return end
        local hh = cc:FindFirstChildOfClass("Humanoid")
        if not hh or hh.Health <= 0 then return end
        startTPHold()
    end)

    char.AncestryChanged:Connect(function(_, parent)
        if not parent then
            stopTPHold()
        end
    end)

    local hum = char:WaitForChild("Humanoid", 5)
    if hum then
        local lastHP = hum.Health

        hum.Died:Connect(function()
            stopTPHold()
            if not ar or sc or ds.enabled or resetting then return end
            task.spawn(de)
        end)

        -- Only used now for pin settle / regen repin. NOT for hit detection.
        hum.HealthChanged:Connect(function(hp)
            if ds.enabled or sc or resetting then
                lastHP = hp
                return
            end
            if pinning then
                if hp > 0.5 and hp < 2 then
                    pinning     = false
                    stableAtOne = true
                end
                lastHP = hp
                return
            end
            if a1 and instantPin and hp > 1.01 and not pinning then
                s1()
            end
            lastHP = hp
        end)
    end

    task.spawn(function()
        local regen = char:WaitForChild("Health", 5)
        if regen and regen:IsA("Script") then regen.Disabled = true end
    end)
end

lp.CharacterAdded:Connect(bd)
if lp.Character then
