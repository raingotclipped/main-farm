-- BIND
----------------------------------------------------------------
local function bd(char)
    rc()
    stopTPHold()
    invOC0 = nil
    sc = true
    pinning, stableAtOne = false, false
    animDetectDebounce = false

    pcall(function()
        if lp:FindFirstChild("kill") then killTarget = lp.kill
        elseif lp.kill then killTarget = lp.kill end
    end)

    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if hrp then
        unanchorAndGround(char)
        if ds.enabled then
            hrp.CFrame = ds.loc
            task.spawn(function()
                for i = 1, 5 do
                    rn.Heartbeat:Wait()
                    if hrp and hrp.Parent then
                        hrp.AssemblyLinearVelocity = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                        hrp.CFrame = ds.loc
                    end
                end
            end)
        end
    end

    task.delay(0.6, function() sc = false; resetting = false end)

    if wsOn then
        task.spawn(function()
            local hum = char:WaitForChild("Humanoid", 5)
            if hum then hum.WalkSpeed = wsVal end
        end)
    end

    if invisEnabled then
        task.spawn(function()
            task.wait(0.4)
            unanchorAndGround(char)
            if invisEnabled and char.Parent then enableInvis(char) end
        end)
    end

    tpSession = tpSession + 1
    local mySession = tpSession
    task.delay(math.max(tpDelay, 0.65), function()
        if mySession ~= tpSession then return end
        if not tpOnSpawn or resetting or ds.enabled then return end
        if not char.Parent then return end
        local hh = char:FindFirstChildOfClass("Humanoid")
        if not hh or hh.Health <= 0 then return end
        startTPHold()
    end)

    char.AncestryChanged:Connect(function(_, parent)
        if not parent then stopTPHold(); disableInvis() end
    end)

    local hum = char:WaitForChild("Humanoid", 5)
    if hum then
        hum.Died:Connect(function()
            stopTPHold(); disableInvis()
            if not ar or sc or ds.enabled or resetting then return end
            task.spawn(de)
        end)
        hum.HealthChanged:Connect(function(hp)
            if ds.enabled or sc or resetting then return end
            if pinning then
                if hp > 0.5 and hp < 2 then pinning, stableAtOne = false, true end
                return
            end
            if a1 and instantPin and hp > 1.01 and not pinning then s1() end
        end)
    end

    task.spawn(function()
        local regen = char:WaitForChild("Health", 5)
        if regen and regen:IsA("Script") then regen.Disabled = true end
    end)
end

lp.CharacterAdded:Connect(bd)
if lp.Character then task.spawn(bd, lp.Character) end
lp.CharacterRemoving:Connect(function() stopTPHold(); disableInvis() end)
