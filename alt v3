----------------------------------------------------------------
-- HOOKS
----------------------------------------------------------------
local oi
oi = hookmetamethod(game, "__index", newcclosure(function(self, k)
    if ds.enabled and not checkcaller() and k == "CFrame" then
        local c = lp.Character
        if c then
            local hrp = c:FindFirstChild("HumanoidRootPart")
            if hrp and self == hrp then return ds.loc end
        end
    end
    return oi(self, k)
end))

local function gc()
    local c = lp.Character
    if c and c.Parent then return c end
    local f = ws:FindFirstChild("Characters")
    return f and f:FindFirstChild(lp.Name)
end

local ncc, cm = nil, {}
local function ncf(dur)
    if ncc then ncc:Disconnect() ncc = nil end
    cm = {}
    local function step()
        local c = gc(); if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then
                if cm[p] == nil then cm[p] = p.CanCollide end
                p.CanCollide = false
            end
        end
    end
    step()
    ncc = rn.Stepped:Connect(step)
    task.delay(dur, function()
        if ncc then ncc:Disconnect() ncc = nil end
        local c = gc()
        if c then
            for p, old in pairs(cm) do
                if p and p.Parent then p.CanCollide = old end
            end
        end
        cm = {}
    end)
end

local function rc() if ncc then ncc:Disconnect() ncc = nil end cm = {} end

local hb

----------------------------------------------------------------
-- SKY-FLOAT FIX
----------------------------------------------------------------
local function unanchorAndGround(char)
    char = char or gc()
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Anchored then
            pcall(function() p.Anchored = false end)
        end
    end
    pcall(function()
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end)
end

----------------------------------------------------------------
-- TP HOLD
----------------------------------------------------------------
local function stopTPHold()
    tpHold = false
    if tpConnHB then tpConnHB:Disconnect() tpConnHB = nil end
    if tpConnST then tpConnST:Disconnect() tpConnST = nil end
end

local function applyLock()
    if not tpHold or resetting or ds.enabled or sc or pinning then return end
    local c = gc()
    local root = c and c:FindFirstChild("HumanoidRootPart")
    if not root or not root.Parent then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if h and (h.Health <= 0 or h:GetState() == Enum.HumanoidStateType.Dead) then
        stopTPHold(); return
    end
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    root.CFrame = CFrame.new(tpX, tpY, tpZ)
end

local function startTPHold()
    stopTPHold()
    if resetting or ds.enabled or sc then return end
    local char = gc(); if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local h = char:FindFirstChildOfClass("Humanoid")
    if h and h.Health <= 0 then return end
    tpHold = true
    tpConnST = rn.Stepped:Connect(applyLock)
    tpConnHB = rn.Heartbeat:Connect(applyLock)
end

----------------------------------------------------------------
-- INVISIBILITY
----------------------------------------------------------------
local function disableInvis()
    invisActive = false
    if invConn then invConn:Disconnect() invConn = nil end
    if invFT then pcall(function() invFT:Destroy() end) invFT = nil end
    if invTrack then pcall(function() invTrack:Stop(0) end) invTrack = nil end

    local c = gc()
    if c then
        local hrp = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if hrp and invOC0 then
            local rj = hrp:FindFirstChild("RootJoint")
                or (c:FindFirstChild("LowerTorso") and c.LowerTorso:FindFirstChild("Root"))
            if rj then pcall(function() rj.C0 = invOC0 end) end
        end
        if hum then hum.AutoRotate = true end
    end

    pcall(function()
        cam.CameraType = Enum.CameraType.Custom
        if lp.Character then
            local hum = lp.Character:FindFirstChildOfClass("Humanoid")
            if hum then cam.CameraSubject = hum end
        end
    end)

    invOC0 = nil
end

local function enableInvis(char)
    if not invisEnabled then return end
    if invisActive then disableInvis() end
    char = char or gc()
    if not char then return end

    local hum = char:WaitForChild("Humanoid", 5)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hum or not hrp then return end

    if hrp.Anchored then pcall(function() hrp.Anchored = false end) end
    local gws = tick()
    while tick() - gws < 1.5 do
        if not hrp or not hrp.Parent then return end
        if math.abs(hrp.AssemblyLinearVelocity.Y) < 3 then break end
        rn.Heartbeat:Wait()
    end

    local rj = hrp:FindFirstChild("RootJoint")
        or (char:FindFirstChild("LowerTorso") and char.LowerTorso:FindFirstChild("Root"))
    if rj then
        invOC0 = rj.C0
        rj.C0 = invOC0 - Vector3.new(0, INVIS_OFF, 0)
    end

    hum.AutoRotate = false
    lp.DevEnableMouseLock = true

    if invFT then pcall(function() invFT:Destroy() end) end
    invFT = Instance.new("Part")
    invFT.Name = "RAINFakeTorso"
    invFT.Size = Vector3.new(2, 2, 1)
    invFT.Transparency = 1
    invFT.CanCollide = false
    invFT.Anchored = true
    invFT.Parent = workspace

    cam.CameraType    = Enum.CameraType.Custom
    cam.CameraSubject = invFT

    if invConn then invConn:Disconnect() end
    invConn = rn.RenderStepped:Connect(function()
        if not invisActive then return end
        local c2 = lp.Character; if not c2 then return end
        local hrp2 = c2:FindFirstChild("HumanoidRootPart"); if not hrp2 then return end

        local rj2 = hrp2:FindFirstChild("RootJoint")
            or (c2:FindFirstChild("LowerTorso") and c2.LowerTorso:FindFirstChild("Root"))
        if rj2 and invOC0 then
            local tgt = invOC0 - Vector3.new(0, INVIS_OFF, 0)
            if rj2.C0 ~= tgt then rj2.C0 = tgt end
        end

        for _, p in ipairs(c2:GetDescendants()) do
            if p:IsA("BasePart") and p.CanCollide then p.CanCollide = false end
        end

        local camCF = cam.CFrame
        local lookV = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z)
        if lookV.Magnitude > 0 then
            hrp2.CFrame = CFrame.new(hrp2.Position, hrp2.Position + lookV.Unit)
        end
        if invFT then invFT.CFrame = hrp2.CFrame * CFrame.new(0, 1.5, 0) end
    end)

    pcall(function()
        local anim = rep.Modules.MVP.Meditation.Character
        invTrack = hum:LoadAnimation(anim)
        invTrack.Priority = Enum.AnimationPriority.Action4
        invTrack:Play()
        task.wait(0.1)
        invTrack.TimePosition = 0.1
        invTrack:AdjustSpeed(0)
        for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
            if t ~= invTrack then t:Stop(0) end
        end
        hum.AnimationPlayed:Connect(function(t)
            if not invisActive then return end
            if t ~= invTrack then t:Stop(0) end
        end)
    end)

    invisActive = true
end

----------------------------------------------------------------
-- RESET METHODS
----------------------------------------------------------------
local function fireResetRE() if rst then pcall(function() rst:FireServer() end) end end
local function fireBreakJoints(h)
    pcall(function() replicatesignal(h.ServerBreakJoints) end)
    pcall(function() h:BreakJoints() end)
end
local function fireHumanoidZero(h)
    pcall(function() h.Health = 0 end)
    pcall(function() h:TakeDamage(math.huge) end)
    if killTarget then
        local sig = replicatesignal or replicate_signal
        if sig then pcall(function() sig(killTarget) end) end
    end
end
local function fireLoadCharacter() pcall(function() lp:LoadCharacter() end) end

local function executeResetMethod(h)
    if resetMethod == "Reset RE" then fireResetRE()
    elseif resetMethod == "BreakJoints" then fireBreakJoints(h)
    elseif resetMethod == "Humanoid Zero" then fireHumanoidZero(h)
    elseif resetMethod == "LoadCharacter" then fireLoadCharacter()
    else fireBreakJoints(h); fireResetRE(); fireHumanoidZero(h) end
end

----------------------------------------------------------------
-- INSTANT RESPAWN
----------------------------------------------------------------
local function de()
    if ds.enabled or resetting then return end
    local c = gc(); if not c then return end
    local r = c:FindFirstChild("HumanoidRootPart")
    local h = c:FindFirstChildOfClass("Humanoid")
    if not r or not h then return end

    resetting = true
    pinning, stableAtOne = false, false
    stopTPHold()

    -- Simple anti-float: disable invis BEFORE killing.
    if invisActive then disableInvis() end

    ds.loc = r.CFrame
    ncf(5)
    ds.enabled = true

    executeResetMethod(h)

    if hb then hb:Disconnect() hb = nil end
    hb = rn.Stepped:Connect(function()
        if not ds.enabled then if hb then hb:Disconnect() hb = nil end return end
        local char = gc()
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root and root.Parent then root.CFrame = CFrame.new(0, 10000, 0) end
    end)

    task.delay(0.6, function()
        ds.enabled = false
        if hb then hb:Disconnect() hb = nil end
    end)
end

local oldNc
oldNc = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if not checkcaller() and self == rst and (method == "FireServer" or method == "fireServer") then
        if ar and not pinning and not sc and not resetting then
            if hb then hb:Disconnect() hb = nil end
            ds.enabled = false
            task.spawn(de)
        end
    end
    return oldNc(self, ...)
end))

----------------------------------------------------------------
-- 1HP
----------------------------------------------------------------
local function s1()
    if resetting or ds.enabled or sc then return end
    local c = gc(); if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if not h or h.Health <= 1.01 then return end
    pinning, stableAtOne = true, false
    pinToken = pinToken + 1
    local myToken = pinToken
    pcall(function()
        if hm == "ChangeState" then h:ChangeState(Enum.HumanoidStateType.Dead)
        elseif hm == "Kill Signal" then
            local sig = replicatesignal or replicate_signal
            if sig and killTarget then sig(killTarget)
            else h:ChangeState(Enum.HumanoidStateType.Dead) end
        end
    end)
    task.delay(pinTimeout, function()
        if myToken == pinToken and pinning then
            pinning, stableAtOne = false, true
        end
    end)
end

local function fr() pinning, stableAtOne = false, false; task.spawn(de) end

task.spawn(function()
    while true do
        task.wait(rt)
        if a1 and not pinning and not sc and not ds.enabled and not resetting then
            local c = gc()
            local h = c and c:FindFirstChildOfClass("Humanoid")
            if h and h.Parent and h.Health > 1.01 then s1() end
        end
    end
end)

----------------------------------------------------------------
-- ANIM WATCHER (aggressive hooking, range-gated trigger)
----------------------------------------------------------------
local function normalizeId(id) if not id then return "" end return tostring(id):match("(%d+)") or "" end

local function buildIdSet()
    local set = {}
    for _, e in ipairs(animList) do
        if e.enabled then
            local n = normalizeId(e.id)
            if n ~= "" then set[n] = true end
        end
    end
    return set
end

local function isLocalHumanoid(hum)
    if not hum then return true end
    local par = hum.Parent
    if not par then return true end
    if lp.Character and par == lp.Character then return true end
    if par.Name == lp.Name then return true end
    local ok, plr = pcall(function() return pl:GetPlayerFromCharacter(par) end)
    if ok and plr == lp then return true end
    local cur = par.Parent
    while cur and cur ~= game do
        if cur == lp.Character then return true end
        if cur.Name == lp.Name and cur:FindFirstChildOfClass("Humanoid") then return true end
        cur = cur.Parent
    end
    return false
end

local function onTrackPlayed(track, sourceHum)
    if not animWatch or animDetectDebounce or resetting or ds.enabled then return end
    if sourceHum and isLocalHumanoid(sourceHum) then return end
    if not track or not track.Animation then return end
    local tid = normalizeId(track.Animation.AnimationId)
    if tid == "" then return end
    if not buildIdSet()[tid] then return end

    local myChar = gc()
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    -- Range gate at TRIGGER time, not at hook time
    if sourceHum and sourceHum.Parent then
        local enemyChar = sourceHum.Parent
        local enemyRoot = enemyChar:FindFirstChild("HumanoidRootPart")
            or enemyChar:FindFirstChild("Torso")
            or enemyChar:FindFirstChild("UpperTorso")
        if not enemyRoot or not enemyRoot:IsA("BasePart") then return end
        local dist = (enemyRoot.Position - myRoot.Position).Magnitude
        if dist > animRange then return end -- ignore but DON'T unhook
    end

    animDetectDebounce = true
    stopTPHold()
    if ar then task.spawn(de) end
    task.delay(0.5, function() animDetectDebounce = false end)
end

local function hookHumanoid(hum)
    if not hum or animTrackedHums[hum] then return end
    if isLocalHumanoid(hum) then return end
    animTrackedHums[hum] = hum.AnimationPlayed:Connect(function(track)
        onTrackPlayed(track, hum)
    end)
    pcall(function()
        for _, tr in ipairs(hum:GetPlayingAnimationTracks()) do
            onTrackPlayed(tr, hum)
        end
    end)
    hum.AncestryChanged:Connect(function(_, parent)
        if not parent and animTrackedHums[hum] then
            animTrackedHums[hum]:Disconnect()
            animTrackedHums[hum] = nil
        end
    end)
end

local function unhookAll()
    for hum, conn in pairs(animTrackedHums) do
        if conn then conn:Disconnect() end
        animTrackedHums[hum] = nil
    end
end

-- Hook on player join + character spawn
for _, p in ipairs(pl:GetPlayers()) do
    if p ~= lp then
        if p.Character then
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if h then hookHumanoid(h) end
        end
        p.CharacterAdded:Connect(function(c)
            local h = c:WaitForChild("Humanoid", 5)
            if h then hookHumanoid(h) end
        end)
    end
end
pl.PlayerAdded:Connect(function(p)
    if p == lp then return end
    p.CharacterAdded:Connect(function(c)
        local h = c:WaitForChild("Humanoid", 5)
        if h then hookHumanoid(h) end
    end)
end)

-- Hook NPCs/characters in workspace Characters folder via DescendantAdded
local function watchCharactersFolder(folder)
    if not folder then return end
    for _, c in ipairs(folder:GetChildren()) do
        if c:IsA("Model") then
            local h = c:FindFirstChildOfClass("Humanoid")
            if h and not isLocalHumanoid(h) then hookHumanoid(h) end
        end
    end
    folder.DescendantAdded:Connect(function(obj)
        if obj:IsA("Humanoid") and not isLocalHumanoid(obj) then
            hookHumanoid(obj)
        end
    end)
end

task.spawn(function()
    local cf = ws:FindFirstChild("Characters")
    if not cf then cf = ws:WaitForChild("Characters", 10) end
    watchCharactersFolder(cf)
end)

-- Safety sweep: catch anything that slipped through (every 0.5s, light)
task.spawn(function()
    while true do
        task.wait(0.5)
        if animWatch then
            for _, p in ipairs(pl:GetPlayers()) do
                if p ~= lp and p.Character then
                    local h = p.Character:FindFirstChildOfClass("Humanoid")
                    if h then hookHumanoid(h) end
                end
            end
            local cf = ws:FindFirstChild("Characters")
            if cf then
                for _, c in ipairs(cf:GetChildren()) do
                    if c:IsA("Model") then
                        local h = c:FindFirstChildOfClass("Humanoid")
                        if h and not isLocalHumanoid(h) then hookHumanoid(h) end
                    end
                end
            end
            -- Cleanup dead hooks
            for hum, conn in pairs(animTrackedHums) do
                if not hum or not hum.Parent then
                    if conn then conn:Disconnect() end
                    animTrackedHums[hum] = nil
                end
            end
        end
    end
end)

