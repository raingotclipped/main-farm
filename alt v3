            table.insert(animList, { id = id, enabled = true, label = "Custom "..(#animList+1) })
            local idx = #animList
            AnimTab:Toggle({
                Title = animList[idx].label.."  ("..animList[idx].id..")", Default = true,
                Callback = function(v) animList[idx].enabled = v end,
            })
        end
    end
end })
